{
  "name": "jinghe-sanjiaoroad-app-monorepo",
  "version": "1.0.0",
  "description": "移动端框架包开发 monorepo 项目",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm -r build",
    "build:app": "pnpm --filter @jinghe-sanjiaoroad-app/app build",
    "dev": "pnpm -r dev",
    "dev:app": "pnpm --filter @jinghe-sanjiaoroad-app/app dev",
    "test": "pnpm -r test",
    "test:app": "pnpm --filter @jinghe-sanjiaoroad-app/app test",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "lint:app": "pnpm --filter @jinghe-sanjiaoroad-app/app lint",
    "lint:fix:app": "pnpm --filter @jinghe-sanjiaoroad-app/app lint:fix",
    "type-check": "pnpm -r type-check",
    "type-check:app": "pnpm --filter @jinghe-sanjiaoroad-app/app type-check",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "clean:app": "pnpm --filter @jinghe-sanjiaoroad-app/app clean",
    "dev:playground": "pnpm --filter jinghe-sanjiaoroad-app-playground dev",
    "build:playground": "pnpm --filter jinghe-sanjiaoroad-app-playground build",
    "lint:playground": "pnpm --filter jinghe-sanjiaoroad-app-playground lint",
    "check:playground": "node scripts/test-framework.js",
    "clean:playground": "pnpm --filter jinghe-sanjiaoroad-app-playground clean",
    "start": "pnpm dev:app",
    "check:all": "pnpm lint:app && pnpm type-check:app && pnpm build:app",
    "prepare:release": "pnpm check:all && pnpm build:app",
    "check": "node scripts/test-framework.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:app": "pnpm build:app && changeset publish",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.0",
    "typescript": "~5.8.0",
    "vite": "5.2.8",
    "vue-tsc": "^3.0.6"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "author": {
    "name": "jinghe-sanjiaoroad-app-team",
    "email": "team@jinghe-sanjiaoroad-app.com",
    "url": "https://github.com/LeftProgrammer/jh-app-monorepo"
  },
  "license": "MIT",
  "homepage": "https://github.com/LeftProgrammer/jh-app-monorepo#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/LeftProgrammer/jh-app-monorepo.git"
  },
  "bugs": {
    "url": "https://github.com/LeftProgrammer/jh-app-monorepo/issues"
  }
}
