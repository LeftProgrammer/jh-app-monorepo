{
  "name": "@jh-app/app",
  "version": "1.0.0",
  "description": "JH App 移动端框架 - 一体化解决方案",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "type-check": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "pinia": "2.0.36",
    "pinia-plugin-persistedstate": "^3.2.0",
    "vue-router": "4.5.1",
    "dayjs": "1.11.10",
    "crypto-js": "^4.2.0",
    "jsencrypt": "^3.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "~5.8.0",
    "vite": "5.2.8",
    "vitest": "^1.0.0",
    "vue-tsc": "^3.0.6"
  },
  "peerDependencies": {
    "@dcloudio/uni-app": "3.0.0-4070620250821001"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "uni-app",
    "vue3",
    "typescript",
    "mobile",
    "framework",
    "all-in-one"
  ],
  "author": "jh-app-team",
  "license": "MIT"
}
