    "./pages/contact": "./src/pages/contact/index.ts",
    "./pages/bpm": "./src/pages/bpm/index.ts",
    "./style": "./src/style/index.scss",
    "./package.json": "./package.json"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "README.md",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "build:types": "vue-tsc --emitDeclarationOnly",
