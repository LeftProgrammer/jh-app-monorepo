{
  "name": "@jinghe-sanjiaoroad-app/app",
  "version": "1.0.0",
  "description": "jinghe-sanjiaoroad App 移动端框架 - 一体化解决方案",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "build:types": "vue-tsc --emitDeclarationOnly",
    "build:watch": "vite build --watch",
    "dev": "vite build --watch",
    "lint": "eslint src --ext .ts,.vue --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepublishOnly": "pnpm -r build",
    "prepublish": "pnpm -r build && pnpm test",
    "publish": "pnpm -r publish --no-git-checks --access public"
  },
  "exports": {
    ".": {
      "import": "./dist/index-*.mjs",
      "require": "./dist/index-*.js",
      "types": "./dist/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.esm.js",
      "require": "./dist/components/index.cjs.js",
      "types": "./dist/components/index.d.ts"
    },
    "./style": "./dist/index.css"
  },
  "dependencies": {
    "@dcloudio/uni-components": "3.0.0-4070620250821001",
    "@dcloudio/uni-h5": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4070620250821001",
    "abortcontroller-polyfill": "^1.7.8",
    "bpmn-js": "17.9.2",
    "bpmn-js-token-simulation": "0.36.0",
    "crypto-js": "^4.2.0",
    "dayjs": "1.11.10",
    "diagram-js": "12.8.0",
    "jsencrypt": "^3.5.4",
    "pinia-plugin-persistedstate": "3.2.1",
    "wot-design-uni": "^1.13.0"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/vite-plugin-uni": "3.0.0-4070620250821001",
    "@uni-helper/eslint-config": "0.5.0",
    "@uni-helper/plugin-uni": "0.1.0",
    "@uni-helper/uni-env": "0.1.8",
    "@uni-helper/uni-types": "1.0.0-alpha.6",
    "@uni-helper/unocss-preset-uni": "0.2.11",
    "@uni-helper/vite-plugin-uni-components": "0.2.3",
    "@uni-helper/vite-plugin-uni-layouts": "0.1.0",
    "@uni-helper/vite-plugin-uni-manifest": "0.1.0",
    "@uni-helper/vite-plugin-uni-pages": "0.3.23",
    "@uni-helper/vite-plugin-uni-platform": "0.0.5",
    "@uni-ku/bundle-optimizer": "^1.0.0",
    "@uni-ku/root": "^1.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "rimraf": "^5.0.5",
    "rollup-plugin-visualizer": "^6.0.3",
    "sass": "^1.97.3",
    "typescript": "~5.8.0",
    "unocss": "66.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.17.9",
    "unplugin-auto-import": "^20.0.0",
    "vite": "5.2.8",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^3.0.6"
  },
  "peerDependencies": {
    "@dcloudio/uni-app": "3.0.0-4070620250821001",
    "vue": "^3.4.21",
    "pinia": "2.0.36"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "pinia": {
      "optional": false
    },
    "@dcloudio/uni-app": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "uni-app",
    "vue3",
    "typescript",
    "mobile",
    "framework",
    "all-in-one"
  ],
  "author": "jinghe-sanjiaoroad-app-team"
}
